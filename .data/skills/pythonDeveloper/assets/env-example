# Skillnir Environment Configuration
# Copy to ~/.skillnir/config.json (JSON format) or set as environment variables

# Backend selection (claude | cursor | gemini | copilot)
SKILLNIR_BACKEND=claude

# Model selection (varies by backend)
# Claude: opus, sonnet, haiku
# Cursor: auto, gpt-5.4, opus, sonnet
# Gemini: auto, 2.5-pro, 2.5-flash
# Copilot: gpt-4o, gpt-5.x, claude-sonnet
SKILLNIR_MODEL=sonnet

# Prompt version (matches .data/promptsv1/ directory naming)
SKILLNIR_PROMPT_VERSION=v1

# NiceGUI settings
NICEGUI_STORAGE_SECRET=skillnir-local
